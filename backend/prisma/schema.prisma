// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Account {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  role      String   // "user" or "company"
  createdAt DateTime @default(now())

  user      User?
  company   Company?
}

model User {
  id                Int      @id @default(autoincrement())
  firstName         String
  lastName          String
  gender            String
  avatar            String?
  resume            String?
  phoneNumber       String? @unique
  bio               String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  accountId         Int     @unique
  account           Account @relation(fields: [accountId], references: [id])
  educations        Education []
  workexperinces    workExperience []
  locationId        Int?
  location          Location? @relation(fields: [locationId], references: [id])

  members           CompanyMembers[]

  applies           Apply[] @relation("Apply")
}

model Company {
  id              Int      @id @default(autoincrement())
  email           String   @unique
  companyName     String   @unique
  logo            String?
  type            String?
  description     String?
  phoneNumber       String? @unique

  createdAt       DateTime
  updatedAt       DateTime @updatedAt
  accountId       Int     @unique
  account         Account @relation(fields: [accountId], references: [id])
  members         CompanyMembers[]
  locationId      Int?
  location        Location? @relation(fields: [locationId], references: [id])

  posts Post[]

  applies Apply[] @relation("Applicants")
}

model CompanyMembers{
  id              Int      @id @default(autoincrement())
  userId          Int
  companyId       Int
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  status          String
  roles           String
  joinedAt        DateTime
  endedAt         DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId, companyId])
}

model Education {
  id                Int      @id @default(autoincrement())
  userId            Int
  schoolName        String
  grade             String
  major             String?
  logo              String?
  joinedAt          DateTime
  endedAt           DateTime
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt         DateTime @default(now())
}

model workExperience {
  id                Int      @id @default(autoincrement())
  userId            Int
  companyName       String
  role              String
  workinghere       Boolean @default(false)
  joinedAt          DateTime
  endedAt           DateTime?
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt         DateTime @default(now())
}

model Location {
  id                Int     @id @default(autoincrement())
  name              String?
  address           String?
  city              String?
  country           String?
  postalCode        String?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  companies Company[]
  users User[]
}

model Post {
  id                Int      @id @default(autoincrement())
  jobtitle          String
  location          String
  requirements      String
  Salary            Float
  description       String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  companyId         Int
  company           Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  applies Apply[]
}

model Apply {
  id                Int      @id @default(autoincrement())
  message           String
  status            String   @default("pending")
  createdAt         DateTime @default(now())

  userId            Int
  companyId         Int
  postId            Int?

  userapply         User     @relation("Apply", fields: [userId], references: [id])
  companyhire       Company  @relation("Applicants", fields: [companyId], references: [id])
  post              Post?    @relation(fields: [postId], references: [id])
}